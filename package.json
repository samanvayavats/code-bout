    "bcrypt": "^6.0.0",
    "dotenv": "^17.2.3",
    "next": "16.1.6",
    "next-auth": "^4.24.14",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-toastify": "^11.1.0",
    "redis": "^5.12.1",
    "ws": "^8.20.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.5.2",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "postcss": "^8.5.16",
    "prettier": "^3.9.5",
    "prisma": "^7.8.0",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.3",
    "typescript": "^5"
